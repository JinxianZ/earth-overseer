rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Validation ---
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.theme in ['dark', 'light', 'neon', 'glitch']
        && data.keys().hasAll(['uid', 'email', 'theme', 'createdAt'])
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) 
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().theme in ['dark', 'light', 'neon', 'glitch']
        && (incoming().updatedAt == request.time)
        && incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'updatedAt', 'displayName']);
    }

    // --- Simulation Validation ---
    function isValidSimulation(data) {
      return data.userId == request.auth.uid
        && data.id is string && data.id.size() <= 128
        && data.headline is string && data.headline.size() <= 500
        && data.probability is number && data.probability >= 0 && data.probability <= 1
        && data.createdAt == request.time;
    }

    match /simulations/{simId} {
      allow get: if isSignedIn() && (resource == null || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSimulation(incoming()) && isValidId(simId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- IntelReport Validation ---
    function isValidReport(data) {
      return data.userId == request.auth.uid
        && data.claim is string && data.claim.size() <= 2000
        && data.verdict is string && data.verdict.size() <= 1000
        && data.isFake is bool
        && data.createdAt == request.time;
    }

    match /intel_reports/{reportId} {
      allow get: if isSignedIn() && (resource == null || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReport(incoming()) && isValidId(reportId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
